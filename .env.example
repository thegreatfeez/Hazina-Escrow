# ─────────────────────────────────────────────
# Hazina Escrow — Environment Variables
# Copy this file to backend/.env and fill in values.
# NEVER commit your real .env file.
# ─────────────────────────────────────────────

# ── Server ────────────────────────────────────
PORT=3001

# The URL of the running frontend (used for CORS).
FRONTEND_URL=http://localhost:5173

# ── Anthropic / Claude ─────────────────────────
# Get your key at https://console.anthropic.com/
ANTHROPIC_API_KEY=sk-ant-api03-...

# ── Stellar Network ────────────────────────────
# "testnet" or "mainnet" — defaults to testnet if unset.
STELLAR_NETWORK=testnet

# Horizon RPC URL. Leave blank to use the default for STELLAR_NETWORK.
# Testnet default : https://horizon-testnet.stellar.org
# Mainnet default : https://horizon.stellar.org
STELLAR_HORIZON_URL=

# ── Escrow Wallet ──────────────────────────────
# The Stellar G... address that receives buyer payments (your platform wallet).
# Buyers send USDC here; the backend forwards 95% to each seller.
ESCROW_WALLET=G...

# ── Agent Wallet ───────────────────────────────
# The secret key (S...) for the autonomous Research Agent's wallet.
# This wallet sends micro-payments to data sellers during research queries.
# Keep this secret. Fund it with ~5 USDC on testnet for development.
# Testnet faucet: https://laboratory.stellar.org/#account-creator
AGENT_WALLET_SECRET=S...

# ── USDC Asset ─────────────────────────────────
# The Stellar account that issued the USDC token on your target network.
# Testnet USDC issuer  : GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet USDC issuer  : GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# ── Platform Fee ───────────────────────────────
# Basis points taken by the platform on each sale (100 = 1%, 500 = 5%).
# Changing this also requires redeploying the Soroban contract.
PLATFORM_FEE_BPS=500
