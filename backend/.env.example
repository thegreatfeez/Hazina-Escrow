PORT=3001
FRONTEND_URL=http://localhost:5173

# API Authentication
# Protects seller write operations (POST /api/datasets, webhook management).
# Generate with: openssl rand -hex 32
API_KEY=your_api_key_here

# Protects admin-only endpoints (backup list, create, restore).
# Generate with: openssl rand -hex 32
ADMIN_API_KEY=your_admin_api_key_here

# Anthropic Claude API
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Stellar USDC issuer — required to prevent XLM or fake-USDC substitution attacks
# Testnet:  GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5
# Mainnet:  GA5ZSEJYB37JRC5AVCIA5MOP4RHTM335X2KGX3IHOJAPP5RE34K4KZVN
USDC_ISSUER=GBBD47IF6LWK7P7MDEVSCWR7DPUWV3NY3DTQEVFL4NAT4AQH3ZLLFLA5

# Stellar Escrow Wallet (testnet) — receives 1 USDC from humans
ESCROW_WALLET=GBVNKDPGVZGFKGRHDUBSZ5V7PXY6PJRFYF5RYVBKAHV3BUXHQWCFXBZ
ESCROW_SECRET=your_escrow_wallet_secret_here

# Platform fee percentage (5%)
PLATFORM_FEE=0.05

# Hazina Research Agent Wallet (testnet) — must be funded with USDC to pay sellers
# Generate a new testnet keypair: https://laboratory.stellar.org/#account-creator?network=test
# Fund it at: https://friendbot.stellar.org/?addr=YOUR_PUBLIC_KEY
# Then add USDC trustline and fund via testnet USDC faucet
AGENT_WALLET_SECRET=your_agent_wallet_secret_here

# Database Backup Configuration
# Enable/disable automated backups (default: true)
BACKUP_ENABLED=true

# Directory where backups are stored (default: backend/backups)
BACKUP_DIR=./backups

# Maximum number of backups to retain (default: 30)
BACKUP_MAX_BACKUPS=30

# Backup schedule in cron format or simple interval
# Cron examples:
#   "0 0 * * *"   = Daily at midnight
#   "0 */6 * * *" = Every 6 hours
#   "0 0 * * 0"   = Weekly on Sunday
#   "*/30 * * * *" = Every 30 minutes
# Simple interval examples:
#   "1h"  = Every hour
#   "30m" = Every 30 minutes
#   "1d"  = Every day
BACKUP_CRON_SCHEDULE=0 0 * * *
